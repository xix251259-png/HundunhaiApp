<?xml version="1.0" encoding="utf-8"?>
<resources>

    <!-- Base application theme. -->
    <style name="Theme.Hundunhai" parent="Theme.MaterialComponents.Light.NoActionBar">
        <!-- Primary brand color. -->
        <item name="colorPrimary">@color/primary</item>
        <item name="colorPrimaryDark">@color/primary_dark</item>
        <item name="colorAccent">@color/gold</item>
        <!-- Status bar color. -->
        <item name="android:statusBarColor">@color/primary_dark</item>
        <!-- Customize your theme here. -->
        <item name="android:windowBackground">@color/bg_color</item>
        <item name="android:textColor">@color/text_color</item>
        <item name="android:textColorSecondary">@color/text_secondary</item>
    </style>
    
    <!-- Dark theme -->
    <style name="Theme.Hundunhai.Dark" parent="Theme.MaterialComponents.NoActionBar">
        <item name="colorPrimary">@color/primary_dark</item>
        <item name="colorPrimaryDark">@color/dark_bg</item>
        <item name="colorAccent">@color/gold_dark</item>
        <item name="android:statusBarColor">@color/dark_bg</item>
        <item name="android:windowBackground">@color/dark_bg</item>
        <item name="android:textColor">@color/dark_text</item>
        <item name="android:textColorSecondary">@color/dark_text_secondary</item>
    </style>
    
    <!-- Blue theme -->
    <style name="Theme.Hundunhai.Blue" parent="Theme.MaterialComponents.Light.NoActionBar">
        <item name="colorPrimary">@color/blue_primary</item>
        <item name="colorPrimaryDark">@color/blue_primary_dark</item>
        <item name="colorAccent">@color/blue_accent</item>
        <item name="android:statusBarColor">@color/blue_primary_dark</item>
        <item name="android:windowBackground">@color/bg_color</item>
    </style>
    
    <!-- Green theme -->
    <style name="Theme.Hundunhai.Green" parent="Theme.MaterialComponents.Light.NoActionBar">
        <item name="colorPrimary">@color/green_primary</item>
        <item name="colorPrimaryDark">@color/green_primary_dark</item>
        <item name="colorAccent">@color/green_accent</item>
        <item name="android:statusBarColor">@color/green_primary_dark</item>
        <item name="android:windowBackground">@color/bg_color</item>
    </style>
    
    <!-- Gold theme -->
    <style name="Theme.Hundunhai.Gold" parent="Theme.MaterialComponents.Light.NoActionBar">
        <item name="colorPrimary">@color/gold_primary</item>
        <item name="colorPrimaryDark">@color/gold_primary_dark</item>
        <item name="colorAccent">@color/gold_accent</item>
        <item name="android:statusBarColor">@color/gold_primary_dark</item>
        <item name="android:windowBackground">@color/bg_color</item>
    </style>

</resources>
